{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "../src/types.ts",
    "../src/cost.ts",
    "../src/compress.ts",
    "../src/optimize.ts",
    "../src/detectors/**/*"
  ]
}
