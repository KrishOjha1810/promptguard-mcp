{
  "name": "@promptguardapp/mcp",
  "version": "0.1.1",
  "description": "Local-first MCP server that scans developer prompts for secrets, PII, and cost before they hit the LLM.",
  "type": "module",
  "bin": {
    "promptguard-mcp": "dist/index.js",
    "promptguard-hook": "dist/hook.js",
    "promptguard-scan-mcp": "dist/mcp-scan/bin.js",
    "promptguard-mcp-session-hook": "dist/mcp-scan/session-hook.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "bench/corpus.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "extension:build": "cd extension && node build.mjs",
    "extension:watch": "cd extension && node build.mjs --watch",
    "extension:typecheck": "cd extension && tsc --noEmit",
    "extension:icons": "node extension/scripts/build-icons.mjs",
    "extension:zip": "npm run extension:build && node extension/scripts/build-zip.mjs",
    "vscode:build": "cd vscode-extension && node esbuild.config.mjs",
    "vscode:watch": "cd vscode-extension && node esbuild.config.mjs --watch",
    "vscode:typecheck": "cd vscode-extension && tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "claude",
    "prompt-safety",
    "secret-scanning",
    "developer-tools"
  ],
  "author": "Krish Ojha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrishOjha1810/promptguard-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/KrishOjha1810/promptguard-mcp/issues"
  },
  "homepage": "https://github.com/KrishOjha1810/promptguard-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.275",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "esbuild": "^0.24.0",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
